# Paperclip Platform — Local Testing Environment
# Copy to .env.local and fill in values.
#
# Stripe test keys: copy from ~/wopr-platform/.env (sk_test_*, whsec_*)
# Generate secrets: openssl rand -hex 32
# Requires /etc/hosts: 127.0.0.1 runpaperclip.com app.runpaperclip.com api.runpaperclip.com

# --- Required ---
PROVISION_SECRET=local-dev-secret-change-me
GATEWAY_URL=https://api.wopr.network/v1
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32

# --- Stripe (test mode — copy all from ~/wopr-platform/.env) ---
STRIPE_SECRET_KEY=sk_test_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_WEBHOOK_SECRET=whsec_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_DEFAULT_PRICE_ID=price_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_CREDIT_PRICE_5=price_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_CREDIT_PRICE_10=price_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_CREDIT_PRICE_25=price_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_CREDIT_PRICE_50=price_COPY_FROM_WOPR_PLATFORM_ENV
STRIPE_CREDIT_PRICE_100=price_COPY_FROM_WOPR_PLATFORM_ENV
EXTRA_ALLOWED_REDIRECT_ORIGINS=http://app.runpaperclip.com:8080

# --- BTCPay Server (crypto payments — set after first-time BTCPay setup) ---
# See RUNBOOK.md "First-time BTCPay setup" for how to get these values.
# BTCPAY_BASE_URL is overridden in docker-compose.local.yml (docker internal URL).
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=

# --- Email (Resend — copy RESEND_API_KEY from ~/wopr-platform/.env) ---
RESEND_API_KEY=re_COPY_FROM_WOPR_PLATFORM_ENV
RESEND_FROM_EMAIL=noreply@runpaperclip.com
FROM_EMAIL=noreply@runpaperclip.com
APP_BASE_URL=http://app.runpaperclip.com:8080

# --- Platform (runpaperclip.com via /etc/hosts for local dev) ---
PLATFORM_DOMAIN=runpaperclip.com
COOKIE_DOMAIN=.runpaperclip.com
UI_ORIGIN=http://app.runpaperclip.com:8080,http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_KEY=local-admin-key
BETTER_AUTH_URL=http://api.runpaperclip.com:8080

# --- Fleet ---
PAPERCLIP_IMAGE=tsavo/paperclip-managed:local
PAPERCLIP_CONTAINER_PORT=3100
FLEET_DATA_DIR=/data/fleet
MAX_INSTANCES_PER_TENANT=5

# --- Inference Gateway ---
OPENROUTER_API_KEY=sk-or-COPY_FROM_OPENROUTER

# --- Caddy (MUST be empty — prevents ProxyManager from overwriting Caddyfile) ---
CADDY_ADMIN_URL=

# --- Database (Postgres — provided by docker-compose.local.yml) ---
# docker-compose.local.yml sets DATABASE_URL in environment block.
POSTGRES_PASSWORD=paperclip-local

# --- Dashboard (platform-ui-core branding) ---
NEXT_PUBLIC_API_URL=http://api.runpaperclip.com:8080
NEXT_PUBLIC_BRAND_PRODUCT_NAME=Paperclip
NEXT_PUBLIC_BRAND_NAME=Paperclip
NEXT_PUBLIC_BRAND_DOMAIN=runpaperclip.com
NEXT_PUBLIC_BRAND_APP_DOMAIN=app.runpaperclip.com:8080
NEXT_PUBLIC_BRAND_TAGLINE=AI agents that run your business.
NEXT_PUBLIC_BRAND_EMAIL_PRIVACY=privacy@runpaperclip.com
NEXT_PUBLIC_BRAND_EMAIL_LEGAL=legal@runpaperclip.com
NEXT_PUBLIC_BRAND_EMAIL_SUPPORT=support@runpaperclip.com
NEXT_PUBLIC_BRAND_DEFAULT_IMAGE=tsavo/paperclip-managed:local
NEXT_PUBLIC_BRAND_STORAGE_PREFIX=paperclip
NEXT_PUBLIC_BRAND_EVENT_PREFIX=paperclip
NEXT_PUBLIC_BRAND_TENANT_COOKIE=paperclip_tenant_id
NEXT_PUBLIC_BRAND_COMPANY_LEGAL=Paperclip AI Inc.
NEXT_PUBLIC_BRAND_PRICE=$5/month
